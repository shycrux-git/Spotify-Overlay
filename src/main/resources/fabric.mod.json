{
	"schemaVersion": 1,
	"id": "spotify-overlay",
	"version": "${version}",
	"name": "Spotify Overlay",
	"description": "Skija in-game Spotify overlay using Windows SMTC, with album art, progress, and synced lyrics. Works with OpenGL and Vulkan.",
	"authors": [
		"Me!"
	],
	"license": "CC0-1.0",
	"environment": "client",
	"accessWidener": "spotify-overlay.accesswidener",
	"entrypoints": {
		"main": [
			{
				"value": "com.spotifyoverlay.SpotifyOverlay",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "com.spotifyoverlay.client.SpotifyOverlayClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"spotify-overlay.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
